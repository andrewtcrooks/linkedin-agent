#!/bin/bash
# search - Query SearXNG with Brave + DDG fallback and result caching
# Usage: search "query" [num_results]
QUERY="$1"
NUM="${2:-10}"
if [ -z "$QUERY" ]; then echo "Usage: search query [num_results]" >&2; exit 1; fi
python3 /home/claw/.openclaw/workspace/bin/search-engine.py "$QUERY" "$NUM"
