#!/usr/bin/env bash
set -euo pipefail

APP_ID="${GITHUB_APP_ID:?GITHUB_APP_ID not set}"
INSTALLATION_ID="${GITHUB_INSTALLATION_ID:?GITHUB_INSTALLATION_ID not set}"
KEY_PATH="${GITHUB_APP_KEY_PATH:?GITHUB_APP_KEY_PATH not set}"

now=$(date +%s)
iat=$((now-60))
exp=$((now+540)) # 9m JWT validity

b64url() { openssl base64 -A | tr '+/' '-_' | tr -d '='; }
header=$(printf '{"alg":"RS256","typ":"JWT"}' | b64url)
payload=$(printf '{"iat":%s,"exp":%s,"iss":"%s"}' "$iat" "$exp" "$APP_ID" | b64url)
unsigned="$header.$payload"
sig=$(printf %s "$unsigned" | openssl dgst -binary -sha256 -sign "$KEY_PATH" | b64url)
jwt="$unsigned.$sig"

resp=$(curl -fsS -X POST \
  -H "Authorization: Bearer $jwt" \
  -H "Accept: application/vnd.github+json" \
  -H "X-GitHub-Api-Version: 2022-11-28" \
  "https://api.github.com/app/installations/$INSTALLATION_ID/access_tokens")

printf '%s' "$resp" | node -e '
let s="";
process.stdin.on("data",d=>s+=d).on("end",()=>{
  const j=JSON.parse(s);
  if(!j.token){
    console.error(s);
    process.exit(2);
  }
  process.stdout.write(j.token);
});'
