#!/usr/bin/env bash
set -euo pipefail

# Workspace-scoped Cognee runtime so data doesn't end up inside the uv tool package dir.
export DATA_ROOT_DIRECTORY="${DATA_ROOT_DIRECTORY:-/home/claw/.openclaw/workspace/.cognee/data}"
export SYSTEM_ROOT_DIRECTORY="${SYSTEM_ROOT_DIRECTORY:-/home/claw/.openclaw/workspace/.cognee/system}"
export CACHE_ROOT_DIRECTORY="${CACHE_ROOT_DIRECTORY:-/home/claw/.openclaw/workspace/.cognee/cache}"
export COGNEE_LOGS_DIR="${COGNEE_LOGS_DIR:-/home/claw/.openclaw/workspace/.cognee/logs}"
export ENABLE_BACKEND_ACCESS_CONTROL="${ENABLE_BACKEND_ACCESS_CONTROL:-false}"

# Use llama_cpp OpenAI-compatible embedding server (already running on :8012)
# fastembed requires internet to download models - not available on this Pi
export EMBEDDING_PROVIDER="${EMBEDDING_PROVIDER:-openai}"
export EMBEDDING_MODEL="${EMBEDDING_MODEL:-openai/bge-small-en-v1.5}"
export EMBEDDING_ENDPOINT="${EMBEDDING_ENDPOINT:-http://127.0.0.1:8012/v1}"
export EMBEDDING_API_KEY="${EMBEDDING_API_KEY:-local}"
export EMBEDDING_DIMENSIONS="${EMBEDDING_DIMENSIONS:-384}"

# Use llama_cpp OpenAI-compatible LLM server (already running on :8011)
export LLM_PROVIDER="${LLM_PROVIDER:-openai}"
export LLM_MODEL="${LLM_MODEL:-openai/qwen2.5-1.5b-instruct}"
export LLM_ENDPOINT="${LLM_ENDPOINT:-http://127.0.0.1:8011/v1}"
export LLM_API_KEY="${LLM_API_KEY:-local}"

# Skip LLM connection test — has no timeout and hangs on slow Pi CPU
export COGNEE_SKIP_CONNECTION_TEST="${COGNEE_SKIP_CONNECTION_TEST:-true}"

mkdir -p "$DATA_ROOT_DIRECTORY" "$SYSTEM_ROOT_DIRECTORY" "$CACHE_ROOT_DIRECTORY" "$COGNEE_LOGS_DIR"

# Keep local compatibility patch applied across cognee reinstalls/upgrades.
if [ -x "/home/claw/.openclaw/workspace/bin/patch-cognee-local" ]; then
  /home/claw/.openclaw/workspace/bin/patch-cognee-local >/dev/null 2>&1 || true
fi

exec "$HOME/.local/bin/cognee-cli" "$@"
