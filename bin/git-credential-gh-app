#!/usr/bin/env bash
# Git credential helper using GitHub App installation token
# Provides short-lived HTTPS credentials (~1hr) via the GitHub App

set -euo pipefail

# Load GitHub App vars from .env if not already set
if [ -z "${GITHUB_APP_ID:-}" ]; then
  eval "$(grep -E '^(GITHUB_APP_ID|GITHUB_INSTALLATION_ID|GITHUB_APP_KEY_PATH)=' /home/claw/.openclaw/.env | sed 's/^/export /')"
fi

case "${1:-get}" in
  get)
    token=$(/home/claw/.openclaw/workspace/bin/gh-app-token)
    printf 'protocol=https\nhost=github.com\nusername=x-access-token\npassword=%s\n' "$token"
    ;;
  store|erase)
    # no-op: tokens are ephemeral
    ;;
esac
